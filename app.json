{
  "expo": {
    "name": "Money Sleuth",
    "slug": "owed-to-you",
    "scheme": "moneysleuth",
    "version": "1.0.0",
    "icon": "./assets/money-sleuth-icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-document-picker",
      "expo-sharing",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F4ED",
          "image": "./assets/money-sleuth-icon.png",
          "imageWidth": 190,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#08050D",
            "image": "./assets/money-sleuth-icon.png"
          }
        }
      ]
    ],
    "android": {
      "package": "com.anonymous.owedtoyou",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/money-sleuth-icon.png",
        "backgroundColor": "#F7F4ED"
      }
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.owedtoyou"
    },
    "extra": {
      "router": {
        "headers": {
          "Cross-Origin-Embedder-Policy": "credentialless",
          "Cross-Origin-Opener-Policy": "same-origin"
        }
      },
      "eas": {
        "projectId": "0cc7f100-9ce2-4e00-af3d-72a653da3588"
      }
    }
  }
}
